# ============================================================
#  Kök .gitignore — hem frontend (node) hem genel kurallar
# ============================================================

# --- Node / Vite (frontend) ---
node_modules
dist
dist-ssr
*.local

# --- Loglar ---
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# --- Python (kök seviyede güvenlik için de) ---
__pycache__/
*.pyc
.venv/
venv/

# --- Yerel yedekler (GitHub'a gitmesin) ---
*.bak
_yedek_orijinal_kod/

# --- Editör / OS ---
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
